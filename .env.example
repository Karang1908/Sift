# Copy this file to .env and fill in your real Ollama API key.
# Get a key at https://ollama.com (sign in, then Settings -> API keys).

# Required: the key authenticates every call to the Ollama cloud API.
OLLAMA_API_KEY=

# Optional overrides - these are the defaults.
OLLAMA_URL=https://ollama.com/api/chat
OLLAMA_MODEL=minimax-m3:cloud
